# Copy this file to .env and fill in real values for local development.
# NEVER commit the real .env file - it is already in .gitignore.

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=social_media_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT - generate a long random string for production, e.g.: openssl rand -base64 48
JWT_SECRET=local-dev-secret-change-me-please-32chars-min
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# CORS - comma separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:3000

# Server
PORT=8080
DDL_AUTO=update
SHOW_SQL=true
LOG_LEVEL=INFO
